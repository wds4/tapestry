# Tapestry Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your nostr public key (hex format, not npub)
# This determines who is the owner/operator of this Tapestry instance
OWNER_PUBKEY=your_hex_pubkey_here

# Neo4j database password
# Choose a strong password — you'll need this to access Neo4j Browser
NEO4J_PASSWORD=change_me_to_something_secure
