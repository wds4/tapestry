// Iterate through all tags to create them and connect them to NostrEvents
CALL apoc.periodic.iterate(
    "CALL apoc.load.json('file:///conceptGraphEventTagsToAddToNeo4j.json') YIELD value AS line RETURN DISTINCT line.id AS id, line.uuid as uuid, line.type AS type, line.value AS value, line.value1 AS value1, line.value2 AS value2, line.value3 AS value3, line.value4 AS value4",
    "MERGE (e:NostrEvent {id: id})
    MERGE (t:NostrEventTag {uuid: uuid})
    SET t.type = type, t.value = value
    SET t.value1 = value1, t.value2 = value2, t.value3 = value3, t.value4 = value4
    MERGE (e)-[:HAS_TAG]->(t)",
    {batchSize:250, parallel:false, retries:3}
);
